{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SecurityAuditPermissions",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeSecurityGroupRules"
      ],
      "Resource": "*"
    },
    {
      "Sid": "S3AuditReportPermissions",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::ec2-backup-logs-*/*"
    }
  ]
}
